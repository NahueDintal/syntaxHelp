    "example": "sudo usermod -aG docker juan",
    "description": "Modifica un usuario existente. -aG añade a grupos."
  },
  {
    "keywords": ["userdel", "eliminar usuario", "borrar"],
    "command": "userdel [opciones] <usuario>",
    "example": "sudo userdel -r juan",
    "description": "Elimina un usuario. -r elimina también su home y mail."
  },
  {
    "keywords": ["passwd", "contraseña", "cambiar"],
    "command": "passwd [usuario]",
    "example": "passwd\nsudo passwd juan",
    "description": "Cambia la contraseña del usuario actual u otro (con sudo)."
  },
  {
    "keywords": ["groupadd", "crear grupo", "nuevo grupo"],
