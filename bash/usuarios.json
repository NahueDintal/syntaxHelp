[
  {
    "keywords": ["useradd", "crear usuario", "añadir usuario"],
    "command": "useradd [opciones] <nombre>",
    "example": "sudo useradd -m -G wheel juan",
    "description": "Crea un nuevo usuario. -m crea home, -G grupos secundarios."
  },
  {
    "keywords": ["usermod", "modificar usuario", "cambiar"],
